# File: .env.example
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_PORT=8080
LOG_LEVEL=info               # debug | info | warn | error
LOG_FORMAT=json              # json | text (use text for local dev)

# ─── Load Balancing ───────────────────────────────────────────────────────────
# Options: round_robin | weighted_round_robin | least_connections | random | ml
LB_STRATEGY=ml

# Comma-separated list of backend server base URLs
SERVERS=http://backend-1:8001,http://backend-2:8002,http://backend-3:8003

# Per-server weights (used only with weighted_round_robin)
# Key pattern: SERVER_WEIGHT_<url-safe-host-port>
SERVER_WEIGHT_backend-1_8001=2
SERVER_WEIGHT_backend-2_8002=1
SERVER_WEIGHT_backend-3_8003=3

# ─── Backend Servers (used when running standalone) ───────────────────────────
BACKEND_PORT=8001            # overridden per-container: 8001, 8002, 8003
BACKEND_INSTANCE_ID=backend-1

# ─── ML Model Service ─────────────────────────────────────────────────────────
ML_MODEL_ENDPOINT=http://ml-service:8081
ML_MODEL_TIMEOUT_MS=300
ML_CIRCUIT_BREAKER_RESET_SECONDS=30
ML_CACHE_SIZE=1000

# ─── PostgreSQL / TimescaleDB ─────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=neurabalancer
DB_USER=neura_user
DB_PASSWORD=changeme_strong_password
DB_SSLMODE=disable           # require in production
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_SERVICE_NAME=neurabalancer
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

PROMETHEUS_ENABLED=true

# ─── Health Check ─────────────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL_SECONDS=5
HEALTH_CHECK_TIMEOUT_SECONDS=3
HEALTH_CHECK_RETRIES=3

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_grafana
